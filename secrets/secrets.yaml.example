# Template — copy to secrets.yaml, fill in values, then encrypt:
#   sops --encrypt secrets/secrets.yaml > secrets/secrets.enc.yaml
#   rm secrets/secrets.yaml
#
# Generate random values with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

database:
  key: "REPLACE_WITH_64_HEX_CHARS"

app:
  secret_key: "REPLACE_WITH_64_HEX_CHARS"

nordigen:
  secret_id: "REPLACE_WITH_GOCARDLESS_SECRET_ID"
  secret_key: "REPLACE_WITH_GOCARDLESS_SECRET_KEY"

token_encryption:
  master_key: "REPLACE_WITH_64_HEX_CHARS"

restic:
  password: "REPLACE_WITH_STRONG_RANDOM_PASSWORD"
  repository: "REPLACE_WITH_RESTIC_REPO_URL"  # e.g. s3:s3.amazonaws.com/bucket/financehub
