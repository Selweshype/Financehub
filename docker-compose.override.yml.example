# Copy to docker-compose.override.yml for local development.
# This file is gitignored when renamed.
#
# Usage: cp docker-compose.override.yml.example docker-compose.override.yml
#
# Overrides for local dev:
#   - age key read from a local path instead of /etc/financehub/
#   - app port exposed to localhost for debugging
#   - Caddy replaced with http-only local proxy

services:
  app:
    volumes:
      - db_data:/data
      - ml_models:/models
      - ./backend/scripts:/scripts:ro
      - ./secrets/age-key-dev.txt:/secrets/age-key.txt:ro   # local dev key
      - ./secrets/secrets.enc.yaml:/secrets/secrets.enc.yaml:ro
    ports:
      - "127.0.0.1:8000:8000"   # expose locally for dev tools
    environment:
      - SOPS_AGE_KEY_FILE=/secrets/age-key.txt
      - PYTHONDONTWRITEBYTECODE=1
      - PYTHONUNBUFFERED=1
      - ENV=development

  caddy:
    volumes:
      - ./infra/caddy/Caddyfile.dev:/etc/caddy/Caddyfile:ro   # http-only local config
      - ./static:/srv/static:ro
      - caddy_data:/data
      - caddy_config:/config
